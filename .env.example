# Shared / Web
NODE_ENV=development
DATABASE_URL=file:./prisma/dev.db
ADMIN_PASSWORD=demo123
AUTOMATION_WEBHOOK_URL=http://automation:8000
PUBLIC_SITE_URL=http://localhost:3000
APP_NAME=JHONROB

# Optional Postgres service (docker-compose profile "postgres")
POSTGRES_DB=jhonrob
POSTGRES_USER=jhonrob
POSTGRES_PASSWORD=jhonrob

# SMTP (used by Python automation)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_TO=contato@jhonrob.com.br
SMTP_FROM=no-reply@jhonrob.local

# Automation service
AUTOMATION_PORT=8000
REPORT_CRON_HOUR=18
TIMEZONE=America/Sao_Paulo
